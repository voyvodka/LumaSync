{
  "name": "lumasync",
  "private": true,
  "version": "1.5.2",
  "description": "Native desktop app that mirrors your screen to WS2812B LED strips and Philips Hue entertainment areas in real time — per-edge room-map calibration, fully local processing.",
  "homepage": "https://lumasync.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voyvodka/LumaSync.git"
  },
  "bugs": {
    "url": "https://github.com/voyvodka/LumaSync/issues"
  },
  "license": "MIT",
  "author": "voyvodka",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm typecheck",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:all": "pnpm lint && pnpm check:rust && pnpm verify:shell-contracts",
    "preview": "vite preview",
    "tauri": "tauri",
    "verify:shell-contracts": "node scripts/verify/phase01-shell-contracts.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
