{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumaSync",
  "version": "0.1.0",
  "identifier": "com.lumasync.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "LumaSync",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4OEFBNjlEOTBEODlBNDYKUldSR210aVFuYWFLdUF4R1U5VDQ3enRuV1NPdHAzaGY0cmhSR0t1YUFIZ2JSbmhxZnRrMmduV24K",
      "endpoints": [
        "https://github.com/voyvodka/LumaSync/releases/latest/download/latest.json"
      ]
    }
  }
}