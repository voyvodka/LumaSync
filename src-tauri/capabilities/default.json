{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main settings window (device, Hue onboarding, Hue stream lifecycle, calibration, and lighting mode commands)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:allow-center",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "opener:default",
    "store:default",
    "window-state:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
