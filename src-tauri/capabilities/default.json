{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main settings window (device, Hue onboarding, Hue stream lifecycle, calibration, lighting mode, platform notification, process relaunch, and log directory commands)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:allow-center",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "core:window:allow-set-max-size",
    "core:window:allow-show",
    "core:window:allow-set-size-constraints",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "opener:default",
    "store:default",
    "window-state:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "dialog:allow-open",
    "fs:allow-copy-file",
    "fs:allow-appdata-write",
    "fs:allow-appdata-read",
    "fs:allow-appdata-read-recursive",
    "notification:default",
    "process:default"
  ]
}
